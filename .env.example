# ─────────────────────────────────────────────────────────────────────────────
# Memory Service — environment configuration
# Copy this file to .env and fill in your values. .env is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED: OpenAI API key for extraction (GPT-4o-mini) and embeddings.
# Without this, the service falls back to a degraded regex-based extractor
# and refuses to compute new embeddings (existing data still queryable via FTS5).
OPENAI_API_KEY=sk-proj-...

# OPTIONAL: Bearer token for HTTP authentication.
# When set, all endpoints (except /health) require: Authorization: Bearer <token>
# When unset, auth is disabled.
MEMORY_AUTH_TOKEN=

# OPTIONAL: Model overrides. Defaults are chosen for cost/quality balance.
# Extraction: gpt-4o-mini is reliable, cheap, and supports temperature=0 for
#   deterministic structured output via function calling. The gpt-5 family
#   rejects explicit temperature, which we rely on for reproducibility.
#   Alternatives: gpt-4o (~10x cost, marginal quality bump), gpt-4.1-mini.
EXTRACTION_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# OPTIONAL: Enable LLM-based reranking of top recall candidates.
# Adds ~300ms latency per /recall call but improves top-k precision.
RERANKER_ENABLED=false

# OPTIONAL: Minimum fused score for a candidate to appear in /recall context.
# Off-topic queries that produce only low-score hits return empty context.
MIN_RECALL_SCORE=0.01

# OPTIONAL: Logging level (DEBUG, INFO, WARNING, ERROR).
LOG_LEVEL=INFO
